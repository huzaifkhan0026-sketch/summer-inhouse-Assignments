   "source": [
    "import numpy as np\n",
    "\n",
    "arr1 = np.array([9, 8, 7, 5])\n",
    "arr2 = np.array([[2, 1],\n",
    "                 [4, 6]])\n",
    "\n",
    "res = arr1.reshape(2, 2)\n",
    "\n",
    "result = np.concatenate((res, arr2), axis=0)\n",
    "\n",
    "print(\"Result of concatenation along axis 0:\\n\", result)"
   ]
  }
