   "source": [
    "# 3. Write a Python function to multiply all the numbers in a list.\n",
    "def multiplylist(lst):\n",
    "    prod = 1\n",
    "\n",
    "    for i in lst:\n",
    "        prod = prod * i\n",
    "\n",
    "    return prod\n",
    "\n",
    "print(multiplylist([10, 2, 23, 45]))\n"
   ]
  }
