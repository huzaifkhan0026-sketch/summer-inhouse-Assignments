    "# 7. Write a Python function to Print Even Numbers from a Given List\n",
    "def even_numbers(n):\n",
    "    for i in n:\n",
    "        if i % 2 == 0:\n",
    "            print(i)\n",
    "\n",
    "even_numbers([1, 2, 3, 4, 5, 6, 7, 8])"
   ]
