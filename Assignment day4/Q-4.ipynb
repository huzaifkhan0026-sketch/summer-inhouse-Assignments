   "source": [
    "# 4. Write a Python function to calculate the factorial of a number (a non-negative integer).\n",
    "#  The function accepts the number as an argument\n",
    "\n",
    "def facto(n):\n",
    "    fact = 1\n",
    "\n",
    "    for i in range(1, n + 1):\n",
    "        fact = fact * i\n",
    "\n",
    "    return fact\n",
    "\n",
    "print(facto(5))"
   ]
  }
 ],
