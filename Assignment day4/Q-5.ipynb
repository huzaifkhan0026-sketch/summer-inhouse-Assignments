   "source": [
    "# 5. Write a Python program to reverse a string.\n",
    "\n",
    "\n",
    "def reverse_string(str):\n",
    "    rever = \"\"\n",
    "\n",
    "    for i in range(len(str)-1, -1, -1):\n",
    "        rever = rever + str[i]\n",
    "\n",
    "    print(rever)\n",
    "\n",
    "reverse_string(\"Programming in python\")"
   ]
  }
