   "source": [
    "# 1. Write a Python function to find the maximum of three numbers.\n",
    "\n",
    "def maximumnumber(a, b, c):\n",
    "    if(a > b and a > c):\n",
    "        print(a)\n",
    "    elif(b > a and b > c):\n",
    "        print(b)\n",
    "    else:\n",
    "        print(c)\n",
    "\n",
    "maximumnumber(2, 3, 4)"
   ]
  }
