   "source": [
    "# 6. Write a Python function to check whether a number falls within a given range.\n",
    "def check_range(n, s, e):\n",
    "    if n in range(s, e + 1):\n",
    "        print(\"Number is within the range\")\n",
    "    else:\n",
    "        print(\"Number is outside the range\")\n",
    "\n",
    "check_range(6, 4, 8)"
   ]
  }
