   "source": [
    "import pandas as pd\n",
    "\n",
    "# Question 1: Convert a series of date-strings to a timeseries\n",
    "\n",
    "dates = pd.Series([\n",
    "    \"2026-01-10\",\n",
    "    \"2026-02-15\",\n",
    "    \"2026-03-20\",\n",
    "    \"2026-04-25\"\n",
    "])\n",
    "\n",
    "timeseries = pd.to_datetime(dates)\n",
    "\n",
    "print(timeseries)"
   ]
  }
