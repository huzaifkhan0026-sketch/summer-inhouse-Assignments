   "source": [
    "# Palindrome Number\n",
    "\n",
    "num = input(\"Enter number: \")\n",
    "\n",
    "rev = num[-1::-1]\n",
    "\n",
    "print(\"Reverse =\", rev)\n",
    "\n",
    "if num == rev:\n",
    "    print(\"Palindrome Number\")\n",
    "else:\n",
    "    print(\"Not Palindrome Number\")\n",
    "    "
   ]
  }
